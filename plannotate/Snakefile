"""
pLannotate Snakemake Pipeline
Modular annotation pipeline for plasmid sequences
"""

import os
from pathlib import Path

# Import for configuration
import plannotate.resources as rsc

# Configuration defaults
configfile: "config.yaml"

# Set default values if not in config
LINEAR = config.get("linear", False)
IS_DETAILED = config.get("is_detailed", False)
YAML_FILE = config.get("yaml_file", rsc.get_yaml_path())
INPUT_SEQ = config.get("input_sequence", "")
OUTPUT_DIR = config.get("output_dir", "results")

# Load database configuration
databases = rsc.get_yaml(YAML_FILE)
DB_NAMES = list(databases.keys())

# Define output files
rule all:
    input:
        f"{OUTPUT_DIR}/final_annotations.csv",
        f"{OUTPUT_DIR}/final_annotations.gbk",
        f"{OUTPUT_DIR}/plasmid_plot.html" if config.get("create_plot", True) else []

rule prepare_sequence:
    """Prepare and validate input sequence for searching"""
    output:
        seq_file = f"{OUTPUT_DIR}/prepared_sequence.fasta",
        seq_info = f"{OUTPUT_DIR}/sequence_info.json"
    params:
        input_seq = INPUT_SEQ,
        linear = LINEAR
    script:
        "scripts/prepare_sequence.py"

rule search_and_score:
    """Search database and calculate scores with feature details"""
    input:
        seq = f"{OUTPUT_DIR}/prepared_sequence.fasta",
        seq_info = f"{OUTPUT_DIR}/sequence_info.json"
    output:
        result = f"{OUTPUT_DIR}/searches/{{db}}_results.csv"
    params:
        db_name = "{db}",
        yaml_file = YAML_FILE
    threads: 1
    script:
        "scripts/search_and_score.py"

rule combine_and_clean:
    """Combine all database results and clean overlapping hits"""
    input:
        results = expand(f"{OUTPUT_DIR}/searches/{{db}}_results.csv", db=DB_NAMES),
        seq_info = f"{OUTPUT_DIR}/sequence_info.json"
    output:
        combined = f"{OUTPUT_DIR}/combined_cleaned.csv"
    params:
        is_detailed = IS_DETAILED
    script:
        "scripts/combine_and_clean.py"

rule finalize_annotations:
    """Finalize annotations with fragment detection and sequence extraction"""
    input:
        annotations = f"{OUTPUT_DIR}/combined_cleaned.csv",
        seq_info = f"{OUTPUT_DIR}/sequence_info.json"
    output:
        final = f"{OUTPUT_DIR}/final_annotations.csv"
    script:
        "scripts/finalize_annotations.py"

rule create_outputs:
    """Generate GenBank file and optional visualization"""
    input:
        annotations = f"{OUTPUT_DIR}/final_annotations.csv",
        seq_info = f"{OUTPUT_DIR}/sequence_info.json"
    output:
        gbk = f"{OUTPUT_DIR}/final_annotations.gbk",
        html = f"{OUTPUT_DIR}/plasmid_plot.html"
    params:
        create_plot = config.get("create_plot", True)
    script:
        "scripts/create_outputs.py"